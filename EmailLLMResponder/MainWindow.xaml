<Window x:Class="EmailLLMResponder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Email LLM Responder" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📧" FontSize="28" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Email LLM Responder" FontSize="20" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Automated Email Response System" FontSize="12"
                                   Foreground="#E0EFFF" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Name="MainTabControl">
            <!-- Email Configuration Tab -->
            <TabItem Header="Email Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Margin="15" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10" Padding="5">
                        <StackPanel Margin="20">
                        <GroupBox Header="IMAP Settings (Incoming Mail)" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="IMAP Server:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="ImapServerTextBox"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="IMAP Port:"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Name="ImapPortTextBox" Width="100"/>
                                    <CheckBox Name="ImapUseSslCheckBox" Content="Use SSL/TLS" IsChecked="True" Margin="20,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="SMTP Settings (Outgoing Mail)" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="SMTP Server:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="SmtpServerTextBox"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="SMTP Port:"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Name="SmtpPortTextBox" Width="100"/>
                                    <CheckBox Name="SmtpUseSslCheckBox" Content="Use SSL/TLS" IsChecked="True" Margin="20,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Authentication" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Email Address:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="EmailAddressTextBox"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Password:"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" Name="EmailPasswordBox"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Monitoring Settings" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Content="Check Interval (sec):"/>
                                <TextBox Grid.Column="1" Name="CheckIntervalTextBox" Width="100" HorizontalAlignment="Left"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="TestEmailButton" Content="Test Connection" Click="TestEmailButton_Click"/>
                            <Button Name="SaveEmailButton" Content="Save Email Config" Click="SaveEmailButton_Click"/>
                        </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- LLM Configuration Tab -->
            <TabItem Header="LLM Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Margin="15" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10" Padding="5">
                        <StackPanel Margin="20">
                        <GroupBox Header="API Settings" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="API Endpoint:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="ApiEndpointTextBox"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="API Key:"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" Name="ApiKeyBox"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Model:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Name="ModelTextBox"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Generation Parameters" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Temperature:"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <Slider Name="TemperatureSlider" Width="200" Minimum="0" Maximum="2" Value="0.7"
                                            TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="TemperatureSlider_ValueChanged"/>
                                    <TextBlock Name="TemperatureValue" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.7"/>
                                </StackPanel>

                                <Label Grid.Row="1" Grid.Column="0" Content="Max Tokens:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Name="MaxTokensTextBox" Width="100" HorizontalAlignment="Left"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="System Prompt" Margin="0,0,0,15">
                            <TextBox Name="SystemPromptTextBox" Height="100" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="TestLLMButton" Content="Test Connection" Click="TestLLMButton_Click"/>
                            <Button Name="SaveLLMButton" Content="Save LLM Config" Click="SaveLLMButton_Click"/>
                        </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Activity Log Tab -->
            <TabItem Header="Activity Log">
                <Border Margin="15" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10" Padding="15">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Name="StartButton" Content="Start Monitoring" Click="StartButton_Click"
                                Style="{StaticResource SuccessButton}" MinWidth="140"/>
                        <Button Name="StopButton" Content="Stop Monitoring" Click="StopButton_Click"
                                Style="{StaticResource DangerButton}" IsEnabled="False" MinWidth="140"/>
                        <TextBlock Name="StatusTextBlock" Margin="20,0,0,0" VerticalAlignment="Center"
                                   Text="Status: Stopped" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="2" CornerRadius="8" Background="{StaticResource SurfaceBrush}">
                        <ScrollViewer Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBox Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap"
                                     Background="#FAFBFC" BorderThickness="0" Padding="12"
                                     FontFamily="Consolas,Courier New" FontSize="12"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalScrollBarVisibility="Auto"/>
                        </ScrollViewer>
                    </Border>

                    <Button Grid.Row="2" Name="ClearLogButton" Content="Clear Log"
                            Click="ClearLogButton_Click" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Name="StatusBarText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
