<Window x:Class="EmailLLMResponder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Email LLM Responder" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📧" FontSize="28" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Email LLM Responder" FontSize="20" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Automated Email Response System" FontSize="12"
                                   Foreground="#E0EFFF" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Name="MainTabControl">
            <!-- Email Configuration Tab -->
            <TabItem Header="Email Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15,12,15,12">

                        <!-- Gmail Notice -->
                        <Border Background="#FFF8E1" BorderBrush="#FFB300" BorderThickness="1"
                                CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#6D4C41">
                                <Run FontWeight="Bold">Gmail users:</Run>
                                <Run>Google blocks regular passwords for third-party apps. You must use an App Password — go to myaccount.google.com/apppasswords, generate one, and paste it in the Password field below.</Run>
                                <LineBreak/>
                                <Run Foreground="#9E7860">Recommended settings: IMAP imap.gmail.com:993 (SSL on) · SMTP smtp.gmail.com:587 (SSL on)</Run>
                            </TextBlock>
                        </Border>

                        <!-- Server Settings -->
                        <TextBlock Text="Server Settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="5,0,0,2"/>
                        <Separator Margin="5,0,5,6"/>

                        <Grid Margin="5,0,5,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="IMAP Server:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ImapServerTextBox"/>
                            <Label Grid.Row="0" Grid.Column="2" Content="Port:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Name="ImapPortTextBox"/>
                            <CheckBox Grid.Row="0" Grid.Column="4" Name="ImapUseSslCheckBox" Content="SSL" IsChecked="True" VerticalAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="SMTP Server:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Name="SmtpServerTextBox"/>
                            <Label Grid.Row="1" Grid.Column="2" Content="Port:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Name="SmtpPortTextBox"/>
                            <CheckBox Grid.Row="1" Grid.Column="4" Name="SmtpUseSslCheckBox" Content="SSL" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Authentication -->
                        <TextBlock Text="Authentication" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="5,0,0,2"/>
                        <Separator Margin="5,0,5,6"/>

                        <Grid Margin="5,0,5,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Email Address:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="EmailAddressTextBox"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Password:" VerticalContentAlignment="Center"/>
                            <PasswordBox Grid.Row="1" Grid.Column="1" Name="EmailPasswordBox"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Check Interval:" VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Name="CheckIntervalTextBox" Width="80"/>
                                <TextBlock Text="seconds" VerticalAlignment="Center" Margin="6,0,0,0"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <Label Grid.Row="3" Grid.Column="0" Content="Subject Filter:" VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Name="SubjectFilterTextBox" Width="200"/>
                                <TextBlock Text="(only reply to emails whose subject contains this text)"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                            <Button Name="TestEmailButton" Content="Test Connection" Click="TestEmailButton_Click"/>
                            <Button Name="SaveEmailButton" Content="Save Email Config" Click="SaveEmailButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- LLM Configuration Tab -->
            <TabItem Header="LLM Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15,12,15,12">

                        <!-- API Settings -->
                        <TextBlock Text="API Settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="5,0,0,2"/>
                        <Separator Margin="5,0,5,6"/>

                        <Grid Margin="5,0,5,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="API Endpoint:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ApiEndpointTextBox"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="API Key:" VerticalContentAlignment="Center"/>
                            <PasswordBox Grid.Row="1" Grid.Column="1" Name="ApiKeyBox"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Model:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="ModelTextBox"/>
                        </Grid>

                        <!-- Generation Parameters -->
                        <TextBlock Text="Generation Parameters" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="5,0,0,2"/>
                        <Separator Margin="5,0,5,6"/>

                        <Grid Margin="5,0,5,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Temperature:" VerticalContentAlignment="Center"/>
                            <Slider Grid.Column="1" Name="TemperatureSlider" Minimum="0" Maximum="2" Value="0.7"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    ValueChanged="TemperatureSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Name="TemperatureValue" Text="0.7"
                                       VerticalAlignment="Center" Margin="8,0,20,0" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Label Grid.Column="3" Content="Max Tokens:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Column="4" Name="MaxTokensTextBox"/>
                        </Grid>

                        <!-- System Prompt -->
                        <TextBlock Text="System Prompt" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="5,0,0,2"/>
                        <Separator Margin="5,0,5,6"/>

                        <TextBox Name="SystemPromptTextBox" Margin="5,0,5,12" Height="100"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                            <Button Name="TestLLMButton" Content="Test Connection" Click="TestLLMButton_Click"/>
                            <Button Name="SaveLLMButton" Content="Save LLM Config" Click="SaveLLMButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Activity Log Tab -->
            <TabItem Header="Activity Log">
                <Border Margin="15" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10" Padding="15">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Name="StartButton" Content="Start Monitoring" Click="StartButton_Click"
                                Style="{StaticResource SuccessButton}" MinWidth="140"/>
                        <Button Name="StopButton" Content="Stop Monitoring" Click="StopButton_Click"
                                Style="{StaticResource DangerButton}" IsEnabled="False" MinWidth="140"/>
                        <TextBlock Name="StatusTextBlock" Margin="20,0,0,0" VerticalAlignment="Center"
                                   Text="Status: Stopped" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="2" CornerRadius="8" Background="{StaticResource SurfaceBrush}">
                        <ScrollViewer Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBox Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap"
                                     Background="#FAFBFC" BorderThickness="0" Padding="12"
                                     FontFamily="Consolas,Courier New" FontSize="12"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalScrollBarVisibility="Auto"/>
                        </ScrollViewer>
                    </Border>

                    <Button Grid.Row="2" Name="ClearLogButton" Content="Clear Log"
                            Click="ClearLogButton_Click" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Name="StatusBarText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
